# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required. Used for query expansion, synthesis, contradiction detection,
# faithfulness evaluation, and text embeddings.
OPENAI_API_KEY=sk-...

# ─── NCBI PubMed ──────────────────────────────────────────────────────────────
# Register free at https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY raises rate limit from 3 req/sec to 10 req/sec — strongly recommended.
# NCBI_EMAIL is required by NCBI policy; requests without it may be blocked.
NCBI_API_KEY=
NCBI_EMAIL=your@email.com

# ─── Semantic Scholar ─────────────────────────────────────────────────────────
# Optional. Without a key the free tier allows 1 req/sec.
# Apply at https://www.semanticscholar.org/product/api
S2_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# For local Docker Compose development. Render overrides this automatically.
DATABASE_URL=postgresql+asyncpg://litlens:litlens@localhost:5432/litlens

# Set to true to use an in-memory FAISS index instead of PostgreSQL+pgvector.
# Useful for development without a running PostgreSQL instance.
USE_FAISS_FALLBACK=false

# ─── Application ──────────────────────────────────────────────────────────────
# URL the Streamlit frontend uses to reach the FastAPI backend.
BACKEND_URL=http://localhost:8000

# development | production | test
ENVIRONMENT=development

# INFO | DEBUG | WARNING | ERROR
LOG_LEVEL=INFO

# ─── Render (auto-populated by Render in production — do not set manually) ────
PORT=8000
